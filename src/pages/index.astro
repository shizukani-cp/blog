---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const articles = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '-');
};
---
<Layout>
  <main id="pages">
    <div class="cards">
      {articles.map((article) => (
        <a class="card" href={`/blog/articles/${article.id}/`}>
          <h3>{article.data.title}</h3>
          <p>{article.data.description}</p>
          <small>{formatDate(article.data.date)}</small>
        </a>
      ))}
    </div>
  </main>
</Layout>
